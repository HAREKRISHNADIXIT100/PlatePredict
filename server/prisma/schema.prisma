// prisma/schema.prisma
// Database URL is configured via DATABASE_URL in .env
// Local dev: SQLite  →  DATABASE_URL="file:./dev.db"
// Production: PostgreSQL  →  DATABASE_URL="postgresql://user:pass@host:5432/dbname"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password_hash   String
  role            String   @default("STUDENT")
  hostel_id       String
  advance_paid    Float    @default(15000)
  current_balance Float    @default(15000)
  fee_due_status  Boolean  @default(false)
  amount_due      Float    @default(0.00)
  reward_points   Float    @default(0.00)
  created_at      DateTime @default(now())

  polls           Poll[]
  meal_attendance MealAttendance[]
  transactions    Transaction[]
  reward_logs     RewardLog[]
  leaves          Leave[]

  @@map("users")
}

model VerificationCode {
  id         String   @id @default(uuid())
  email      String
  otp_code   String
  expires_at DateTime
  is_used    Boolean  @default(false)

  @@map("verification_codes")
}

model Menu {
  id               String   @id @default(uuid())
  meal_date        DateTime
  meal_type        String
  items            String   // JSON string array
  serve_time       DateTime
  poll_cutoff_time DateTime
  rewards_processed Boolean @default(false)

  polls           Poll[]
  meal_attendance MealAttendance[]
  reward_logs     RewardLog[]

  @@map("menus")
}

model Poll {
  id         String   @id @default(uuid())
  student_id String
  menu_id    String
  intention  String
  voted_at   DateTime @default(now())

  student     User         @relation(fields: [student_id], references: [id])
  menu        Menu         @relation(fields: [menu_id], references: [id])

  @@unique([student_id, menu_id])
  @@map("polls")
}

model MealAttendance {
  id               String   @id @default(uuid())
  student_id       String
  menu_id          String
  scanned_at       DateTime @default(now())
  deduction_amount Float

  student User @relation(fields: [student_id], references: [id])
  menu    Menu @relation(fields: [menu_id], references: [id])

  @@map("meal_attendance")
}

model RewardLog {
  id         String   @id @default(uuid())
  student_id String
  menu_id    String
  points     Float
  reason     String   // "MEAL_SKIP_REWARD" or "NO_SHOW_VIOLATION_FINE"
  created_at DateTime @default(now())

  student User @relation(fields: [student_id], references: [id])
  menu    Menu @relation(fields: [menu_id], references: [id])

  @@map("reward_logs")
}

model Transaction {
  id             String   @id @default(uuid())
  student_id     String
  amount         Float
  gateway_ref_id String   @unique
  status         String
  paid_at        DateTime @default(now())

  student User @relation(fields: [student_id], references: [id])

  @@map("transactions")
}

model Leave {
  id         String   @id @default(uuid())
  student_id String
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())

  student User @relation(fields: [student_id], references: [id])
  @@map("leaves")
}
